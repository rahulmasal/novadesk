# ============================================
# NovaDesk Environment Variables
# ============================================
# Copy this to .env and fill in your values
# ============================================

# Database Connection (PostgreSQL)
# For Docker Compose: postgresql://novadesk:your_password@db:5432/novadesk
# For local: postgresql://postgres:postgres@localhost:5432/novadesk
# For Supabase: postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=

# Security
# Generate a secure random string for cron jobs: openssl rand -hex 32
CRON_SECRET=your-secure-random-string-here

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NovaDesk

# SMTP Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
REPORT_RECIPIENT=admin@company.com

# LDAP / Active Directory (optional)
# Set NEXT_PUBLIC_LDAP_ENABLED=true to show LDAP login option
NEXT_PUBLIC_LDAP_ENABLED=false
LDAP_ENABLED=false
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=company,dc=com
LDAP_BIND_PASSWORD=your-ldap-password
LDAP_SEARCH_BASE=dc=company,dc=com
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# Software Update Server (optional)
# Set to a URL returning JSON with version info
# UPDATE_SERVER_URL=https://your-update-server.com/version.json

# PostgreSQL Password (for Docker Compose only)
POSTGRES_PASSWORD=your_secure_password_here